/dts-v1/;
/plugin/;

/ {
	compatible = "brcm,bcm2835";

	fragment@0 {
		target = <&i2c0if>;
		__overlay__ {
			status = "okay";
		};
	};

	clk_frag: fragment@1 {
		target = <&cam0_clk>;
		__overlay__ {
			status = "okay";
			clock-frequency = <0x16e3600>;  /* 24MHz */
		};
	};

	fragment@2 {
		target = <&i2c0mux>;
		__overlay__ {
			status = "okay";
		};
	};

	reg_frag: fragment@3 {
		target = <&cam0_reg>;
		cam_reg: __overlay__ {
			startup-delay-us = <0x11170>;
			off-on-delay-us = <0x7530>;
			regulator-min-microvolt = <0x2932e0>;
			regulator-max-microvolt = <0x2932e0>;
		};
	};

	fragment@4 {
		target = <&cam_node>;
		__overlay__ {
			lens-focus = <&vcm_node>;
		};
	};

	i2c_frag: fragment@100 {
		target = <&i2c_csi_dsi0>;
		__overlay__ {
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			status = "okay";

			cam_node: imx708@1a {
				compatible = "sony,imx708";
				reg = <0x1a>;
				status = "okay";
				clocks = <&cam0_clk>;
				clock-names = "inclk";
				vana1-supply = <&cam0_reg>;
				vana2-supply = <&cam_dummy_reg>;
				vdig-supply = <&cam_dummy_reg>;
				vddl-supply = <&cam_dummy_reg>;
				rotation = <0x00>;
				orientation = <0x00>;

				port {
					cam_endpoint: endpoint {
						clock-lanes = <0x00>;
						data-lanes = <0x01 0x02>;
						clock-noncontinuous;
						link-frequencies = <0x00 0x1ad27480>;
						remote-endpoint = <&csi_ep>;
					};
				};
			};

			vcm_node: dw9817@c {
				compatible = "dongwoon,dw9817-vcm";
				reg = <0x0c>;
				status = "okay";
				VDD-supply = <&cam0_reg>;
			};
		};
	};

	csi_frag: fragment@101 {
		target = <&csi0>;
		csi: __overlay__ {
			status = "okay";
			port {
				csi_ep: endpoint {
					remote-endpoint = <&cam_endpoint>;
					clock-lanes = <0x00>;
					data-lanes = <0x01 0x02>;
					clock-noncontinuous;
				};
			};
		};
	};

	fragment@102 {
		target = <&csi0>;
		__dormant__ {
			compatible = "brcm,bcm2835-unicam-legacy";
		};
	};

	__overrides__ {
		rotation = <&cam_node>, "rotation:0";
		orientation = <&cam_node>, "orientation:0";
		media-controller = [00 00 00 00 21 31 30 32 00];
		vcm = <&vcm_node>, "status", "", "", "", "", "=4";
		link-frequency = <&cam_endpoint>, "link-frequencies#0";
	};
};